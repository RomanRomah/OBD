-- 1. ОЧИЩЕННЯ ТА ВИДАЛЕННЯ (DELETE)
-- ---------------------------------------------------------

-- Видалення тестового клієнта, який не робив замовлень
DELETE FROM customers 
WHERE email = 'ivan@outlook.com';

-- Видалення застарілої категорії, якщо вона порожня
DELETE FROM categories 
WHERE name = 'Планшети';

-- Видалення конкретного товару, який знято з виробництва
DELETE FROM products 
WHERE name = 'Samsung Galaxy S23';


