-- 3. ОНОВЛЕННЯ ДАНИХ (UPDATE)
-- ---------------------------------------------------------

-- Проведення акції: знижка на всі смартфони (категорія 1)
UPDATE products
SET price = price * 0.9
WHERE category_id = 1;

-- Зміна пошти клієнта (зміна контактних даних)
UPDATE customers
SET email = 'roman_new_2026@kpi.ua'
WHERE first_name = 'Роман';

-- Оновлення назви товару для уточнення специфікації
UPDATE products
SET name = 'iPhone 15 Pro Max 256GB'
WHERE name = 'iPhone 15';


-- 4. ВИБІРКА ТА ПЕРЕГЛЯД (SELECT)
-- ---------------------------------------------------------

-- Отримання списку всіх зареєстрованих клієнтів
SELECT * FROM customers;

-- Перегляд товарів, ціна яких перевищує 30 000 грн (преміум сегмент)
SELECT name, price 
FROM products
WHERE price > 30000;

-- Перегляд усіх замовлень, зроблених сьогодні
SELECT * FROM orders
WHERE order_date >= CURRENT_DATE;

-- Пошук товарів у конкретній категорії (наприклад, Ноутбуки)
SELECT * FROM products
WHERE category_id = 2;

-- Перегляд вмісту кошика (деталізація замовлень)
